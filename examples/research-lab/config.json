{
  "workspace": "~/research",
  "gateway": {
    "port": 48391,
    "name": "director",
    "role": "research-director",
    "model": "strategic-default"
  },
  "agents": [
    {
      "name": "analyst",
      "port": 48420,
      "role": "data-analyst",
      "model": "review-default",
      "tokenEnv": "FLEET_ANALYST_TOKEN"
    },
    {
      "name": "writer",
      "port": 48440,
      "role": "technical-writer",
      "model": "review-default",
      "tokenEnv": "FLEET_WRITER_TOKEN"
    },
    {
      "name": "scraper",
      "port": 48460,
      "role": "web-scraping",
      "model": "coding-default",
      "tokenEnv": "FLEET_SCRAPER_TOKEN"
    },
    {
      "name": "fact-checker",
      "port": 48480,
      "role": "verification",
      "model": "coding-default",
      "tokenEnv": "FLEET_FACT_CHECKER_TOKEN"
    }
  ],
  "endpoints": [
    {
      "name": "dashboard",
      "url": "https://research.mysite.com"
    }
  ],
  "repos": [
    {
      "name": "reports",
      "repo": "myorg/research-reports"
    },
    {
      "name": "data-pipeline",
      "repo": "myorg/data-pipeline"
    }
  ]
}
