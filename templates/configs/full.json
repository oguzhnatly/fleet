{
  "workspace": "~/workspace",
  "gateway": {
    "port": 48391,
    "name": "coordinator",
    "role": "coordinator",
    "model": "strategic-default"
  },
  "agents": [
    {
      "name": "coder",
      "port": 48520,
      "role": "implementation",
      "model": "coding-default",
      "tokenEnv": "FLEET_CODER_TOKEN"
    },
    {
      "name": "reviewer",
      "port": 48540,
      "role": "code-review",
      "model": "coding-default",
      "tokenEnv": "FLEET_REVIEWER_TOKEN"
    },
    {
      "name": "deployer",
      "port": 48560,
      "role": "deployment",
      "model": "coding-default",
      "tokenEnv": "FLEET_DEPLOYER_TOKEN"
    },
    {
      "name": "qa",
      "port": 48580,
      "role": "quality-assurance",
      "model": "coding-default",
      "tokenEnv": "FLEET_QA_TOKEN"
    },
    {
      "name": "researcher",
      "port": 48600,
      "role": "research",
      "model": "coding-default",
      "tokenEnv": "FLEET_RESEARCHER_TOKEN"
    }
  ],
  "endpoints": [
    {
      "name": "website",
      "url": "https://example.com",
      "expectedStatus": 200
    },
    {
      "name": "api",
      "url": "https://api.example.com/health",
      "expectedStatus": 200
    },
    {
      "name": "docs",
      "url": "https://docs.example.com",
      "expectedStatus": 200,
      "timeout": 10
    }
  ],
  "runtimes": [
    {
      "name": "billing-api",
      "adapter": "http",
      "url": "https://billing.example.com/health",
      "expectedStatus": 200
    },
    {
      "name": "postgres",
      "adapter": "docker",
      "container": "postgres"
    },
    {
      "name": "tailscaled",
      "adapter": "process",
      "process": "tailscaled"
    }
  ],
  "repos": [
    {
      "name": "frontend",
      "repo": "myorg/frontend"
    },
    {
      "name": "backend",
      "repo": "myorg/backend"
    },
    {
      "name": "mobile",
      "repo": "myorg/mobile"
    },
    {
      "name": "infra",
      "repo": "myorg/infrastructure"
    }
  ],
  "services": [
    "openclaw-gateway",
    "openclaw-gateway-coder",
    "openclaw-gateway-reviewer"
  ],
  "linear": {
    "teams": [
      "PROJ"
    ],
    "apiKeyEnv": "LINEAR_API_KEY"
  },
  "skillsDir": "",
  "constitution": {
    "enabled": true,
    "title": "Operator Constitution",
    "mode": "prepend",
    "rules": [
      "Read project instructions before editing files",
      "Run the smallest meaningful verification before reporting completion",
      "Do not rewrite shared git history unless the operator explicitly declares an emergency"
    ],
    "applyTo": [
      "task",
      "parallel",
      "steer"
    ],
    "required": false
  }
}
